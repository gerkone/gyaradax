    "fig_flux = plot_flux_trace(t_demo, (heat_flux,), labels=[\"Heat Flux\"], title=\"Simulated Heat Flux Growth\")\n",
    "plt.show()\n",
    "\n",
    "# 3. Demonstrate Mode Growth (requires a history, run a short scan for this)\n",
    "def run_history(df_init, nsteps=40):\n",
    "    params = GKParams(dt=0.01)\n",
    "    state = default_state()\n",
    "    \n",
    "    def _step_fn(carry, _):\n",
    "        d, s = carry\n",
    "        # Use gkstep_single for manual history tracking\n",
    "        from gyaradax import gkstep_single\n",
    "        dn, (pn, _), sn = gkstep_single(d, geom, params, s)\n",
    "        return (dn, sn), pn\n",
    "    \n",
    "    (_, _), phi_hist = jax.lax.scan(_step_fn, (df_init, state), None, length=nsteps)\n",
    "    return phi_hist\n",
    "\n",
    "phi_history = np.asarray(run_history(df0, nsteps=40))\n",
    "t_history = 0.01 * np.arange(40)\n",
    "ds = float(np.asarray(geom['ints'])[0])\n",
    "fig_growth = plot_mode_growth(t_history, phi_history, ky_indices=[1, 4, 8], ky_values=ky, ds=ds)\n",
    "plt.show()"
   ]
